# --- Server ---
PORT=3824
CLIENT_URL=http://__HOSTNAME__.local:8193

# --- Database (SQLite) ---
DB_TYPE=sqlite
DB_PATH=__DEPLOY_DIR__/data/jira.sqlite

# --- Security ---
JWT_SECRET=__JWT_SECRET__
NODE_ENV=production

# --- Jira integrations (optional) ---
# INTERNAL_ATLASSIAN_BASE_URL=https://your-jira.atlassian.net
# INTERNAL_JIRA_AUTH_TYPE=basic
# INTERNAL_JIRA_EMAIL=your@email.com
# INTERNAL_JIRA_API_TOKEN=your-api-token
