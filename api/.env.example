# --- Server ---
PORT=3000
CLIENT_URL=http://localhost:8080

# --- Database (SQLite for development) ---
DB_TYPE=sqlite
DB_PATH=data/jira.sqlite

# For PostgreSQL:
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_DATABASE=jira

# --- Jira integrations (Internal + External Jira) - optional ---
# APP_DEFAULT_TIMEZONE=America/New_York
# INTERNAL_ATLASSIAN_BASE_URL=https://your-internal-jira.atlassian.net
# INTERNAL_JIRA_AUTH_TYPE=basic
# INTERNAL_JIRA_EMAIL=your_email@company.com
# INTERNAL_JIRA_API_TOKEN=your_internal_jira_api_token
# INTERNAL_JIRA_FIXED_ISSUE_KEY=VIS-2
# EXTERNAL_ATLASSIAN_BASE_URL=https://your-external-jira.atlassian.net
# EXTERNAL_JIRA_AUTH_TYPE=basic
# EXTERNAL_JIRA_EMAIL=your_email@company.com
# EXTERNAL_JIRA_API_TOKEN=your_external_jira_api_token
# EXTERNAL_MY_ACCOUNT_ID=...  # Optional. "Assignee=me" works with just email+token (JQL currentUser())
# HTTP_CONNECT_TIMEOUT_MS=5000
# HTTP_READ_TIMEOUT_MS=10000
